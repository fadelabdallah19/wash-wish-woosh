{
  "version": 2,
  "outputDirectory": "public/build",
  "installCommand": "npm install --ignore-scripts",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    {
      "src": "^/assets/(.*)",
      "dest": "public/assets/$1"
    },
    {
      "src": "^/build/(.*)",
      "dest": "public/build/$1"
    },
    {
      "src": "^/favicon.ico",
      "dest": "public/favicon.ico"
    },
    {
      "src": "^/robots.txt",
      "dest": "public/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false"
  }
}
