{
  "version": 2,
  "outputDirectory": "public",
  "installCommand": "npm install --ignore-scripts",
  "buildCommand": "npm run build",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "^/assets/(.*)",
      "dest": "public/assets/$1"
    },
    {
      "src": "^/build/(.*)",
      "dest": "public/build/$1"
    },
    {
      "src": "^/favicon\\.ico$",
      "dest": "public/favicon.ico"
    },
    {
      "src": "^/robots\\.txt$",
      "dest": "public/robots.txt"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "true",
    "APP_KEY": "base64:Vyv5aTovA4ljbk3aYhHcuyUQwOELOxQTtICIqNTxqQI=",
    "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
    "APP_CONFIG_CACHE": "/tmp/storage/framework/cache/config.php",
    "APP_EVENTS_CACHE": "/tmp/storage/framework/cache/events.php",
    "APP_PACKAGES_CACHE": "/tmp/storage/framework/cache/packages.php",
    "APP_ROUTES_CACHE": "/tmp/storage/framework/cache/routes.php",
    "APP_SERVICES_CACHE": "/tmp/storage/framework/cache/services.php",
    "LOG_CHANNEL": "stderr",
    "SESSION_DRIVER": "array",
    "CACHE_STORE": "array",
    "DB_CONNECTION": "sqlite",
    "DB_DATABASE": "/tmp/database/database.sqlite",
    "ADMIN_USERNAME": "admin",
    "ADMIN_PASSWORD": "$2y$12$Hju/t9jFdjbEOQmVcJtkDuggh.8jiguqb35Y2dgODHRQdEDTYLUZS"
  }
}
